# Groq LLM (https://console.groq.com/). Leave unset to use built-in mock client.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com
LLM_MOCK=false
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

TOP_N_RECOMMENDATIONS=3

# Comma-separated frontend origins for CORS (add your Vercel production URL)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional: allow Vercel preview deployments (used with CORS_ORIGINS)
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Logging (Railway: set LOG_FORMAT=json)
LOG_LEVEL=INFO
LOG_FORMAT=text

CARDS_DATA_PATH=
AA_DATA_PATH=

# --- Frontend (Vercel) — set in Vercel project env, not in backend .env ---
# VITE_API_BASE_URL=https://your-service.up.railway.app/api/v1
